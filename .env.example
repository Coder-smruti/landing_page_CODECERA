# Production site URL
NEXT_PUBLIC_SITE_URL=https://web.codecera.com

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Web3Forms — required for contact form emails
# 1. Go to https://web3forms.com → enter icodecera@gmail.com → get Access Key
# 2. Add in Vercel Environment Variables (Production)
# 3. Redeploy — NEXT_PUBLIC_ vars only apply after a new deploy
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# Production site URL
NEXT_PUBLIC_SITE_URL=https://web.codecera.com

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Web3Forms — recommended for reliable form emails
# 1. Go to https://web3forms.com
# 2. Enter icodecera@gmail.com → copy Access Key
# 3. Add as WEB3FORMS_ACCESS_KEY in Vercel Environment Variables
WEB3FORMS_ACCESS_KEY=your-access-key-here

# Google Tag Manager (for Google Ads conversion tracking)
# 1. Create container at https://tagmanager.google.com
# 2. Paste your GTM ID below (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Site URL (used for FormSubmit delivery)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Option 1 (recommended): Web3Forms — free, reliable, works server-side
# 1. Go to https://web3forms.com
# 2. Enter icodecera@gmail.com and get your access key
# 3. Paste it below
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Option 2: Gmail SMTP — send directly from Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=icodecera@gmail.com
SMTP_PASS=your-gmail-app-password

# Create Gmail App Password: https://myaccount.google.com/apppasswords

# Production site URL
NEXT_PUBLIC_SITE_URL=https://web.codecera.com

# Google Ads gtag (AW-17589112703)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17589112703
# Optional: form conversion label from Google Ads conversion action setup
# NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=AbCdEfGhIjK

# Google Tag Manager (optional, if using GTM alongside gtag)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Web3Forms — required for contact form emails
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here
